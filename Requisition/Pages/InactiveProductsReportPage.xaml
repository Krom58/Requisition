<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Requisition.Pages.InactiveProductsReportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Requisition.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,16">
            <TextBlock Text="📦 รายงานสินค้าถูกยกเลิก (Inactive)"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
            <TextBlock Text="แสดงสินค้าที่ถูกปิดการใช้งาน พร้อมเหตุผลและผู้ดำเนินการ — ค้นหาด้วยชื่อ/รหัส/ประเภท"
                       FontSize="14"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- Filters -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
            <TextBox x:Name="SearchBox"
                     Header="ค้นหา (ชื่อ/รหัส)"
                     Width="260"
                     PlaceholderText="พิมพ์ชื่อหรือรหัส..."
                     TextChanged="SearchBox_TextChanged"/>

            <ComboBox x:Name="CategoryCombo"
                      Header="ประเภท"
                      Width="180"
                      SelectionChanged="CategoryCombo_SelectionChanged">
                <ComboBoxItem Content="ทั้งหมด" Tag="All" IsSelected="True"/>
            </ComboBox>

            <Button x:Name="RefreshButton"
                    Content="🔄 รีเฟรช"
                    Click="RefreshButton_Click"
                    Padding="12,8"/>

            <Button x:Name="ExportButton"
                    Content="📤 ส่งออก CSV"
                    Click="ExportButton_Click"
                    Padding="12,8"
                    Style="{StaticResource AccentButtonStyle}"/>
            <Button x:Name="PrintButton"
        Content="🖨️ พิมพ์"
        Click="PrintButton_Click"
        Padding="12,8"/>
        </StackPanel>

        <!-- Content -->
        <Grid Grid.Row="2">
            <ProgressRing x:Name="LoadingRing"
                          IsActive="False"
                          Width="60"
                          Height="60"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>

            <ListView x:Name="ReportListView"
                      Visibility="Collapsed"
                      SelectionMode="None">
                <ListView.Header>
                    <Grid Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/> <!-- Code -->
                            <ColumnDefinition Width="2*"/>  <!-- Name -->
                            <ColumnDefinition Width="*"/>   <!-- Category -->
                            <ColumnDefinition Width="*"/>  <!-- Unit -->
                            <ColumnDefinition Width="2*"/>  <!-- Reason -->
                            <ColumnDefinition Width="*"/> <!-- DisabledBy / Date -->
                            <ColumnDefinition Width="*"/> <!-- Manage -->
                        </Grid.ColumnDefinitions>

                        <!-- align headers to match ItemTemplate columns -->
                        <TextBlock Text="รหัส"
                                   Grid.Column="0"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="สินค้า"
                                   Grid.Column="1"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="ประเภท"
                                   Grid.Column="2"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="หน่วย"
                                   Grid.Column="3"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="เหตุผลการปิด"
                                   Grid.Column="4"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="โดย / วันที่"
                                   Grid.Column="5"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="จัดการ"
                                   Grid.Column="6"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Grid>
                </ListView.Header>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,6" Padding="12"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="8"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding ProductCode}" FontSize="13" Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="{Binding ProductName}" FontSize="15" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextTrimming="CharacterEllipsis" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding ShortRemarks}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{Binding Category}" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="{Binding Unit}" FontSize="13" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="4" Text="{Binding DisabledReason}" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" HorizontalAlignment="Center"/>

                                <StackPanel Grid.Column="5" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding DisabledBy}" FontSize="12" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{Binding DisabledAtDisplay}" FontSize="11" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Button Content="✅ เปิดใช้งาน"
                                            Tag="{Binding ProductCode}"
                                            Click="EnableButton_Click"
                                            Padding="8,6"
                                            FontSize="12"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel x:Name="EmptyStatePanel"
                        Visibility="Collapsed"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12">
                <TextBlock Text="ไม่มีสินค้าที่ถูกยกเลิก"
                           FontSize="16"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
