<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Requisition.Pages.TransferListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Requisition.Pages"
    xmlns:models="using:Requisition.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,16">
            <TextBlock Text="📋 สร้างใบTransfer" 
                       Style="{StaticResource TitleTextBlockStyle}" 
                       FontWeight="Bold"
                       FontSize="28"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
            <TextBlock Text="สร้างใบTransfer เบิกเพิ่ม และคืนสินค้า" 
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       FontSize="15"/>
        </StackPanel>

        <!-- Action Bar -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left Side: Refresh + Status Filter -->
            <StackPanel Grid.Column="0" 
                        Orientation="Horizontal" 
                        Spacing="12"
                        VerticalAlignment="Center">
                <Button Content="🔄 รีเฟรช" 
                        Click="RefreshButton_Click"
                        VerticalAlignment="Center"
                        FontSize="14"
                        Padding="12,8"/>
                
                <!-- Status Filter -->
                <StackPanel Orientation="Horizontal" 
                            Spacing="8" 
                            VerticalAlignment="Center">
                    <TextBlock Text="สถานะ:" 
                               VerticalAlignment="Center"
                               Margin="0,0,0,0"
                               FontSize="15"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    <ComboBox x:Name="StatusFilter"
                              Width="170"
                              VerticalAlignment="Center"
                              SelectionChanged="StatusFilter_SelectionChanged"
                              FontSize="14"/>
                </StackPanel>
            </StackPanel>

            <!-- Center: Search Box -->
            <AutoSuggestBox x:Name="TransferSearchBox"
                            Grid.Column="1"
                            PlaceholderText="🔍 ค้นหาเลขที่ใบTransfer, ผู้สร้าง, หมายเหตุ..."
                            QueryIcon="Find"
                            TextChanged="TransferSearchBox_TextChanged"
                            Width="400"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Margin="16,0"/>

            <!-- Right Side: Create Button -->
            <Button Grid.Column="2"
                    Content="➕ สร้างใบTransferใหม่" 
                    Click="CreateButton_Click"
                    Style="{StaticResource AccentButtonStyle}"
                    VerticalAlignment="Center"
                    FontSize="14"
                    Padding="14,8"/>
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="2">
            <ProgressRing x:Name="LoadingRing" 
                          IsActive="False" 
                          Width="60" 
                          Height="60"/>

            <ListView x:Name="TransferListView"
                      SelectionMode="None"
                      Visibility="Collapsed"
                      ItemContainerStyle="{StaticResource ListViewItemStyle}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Transfer">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="8"
                                Padding="20"
                                Margin="0,8"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Header Row -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <TextBlock Text="{x:Bind TransferNo}" 
                                                       FontSize="20" 
                                                       FontWeight="SemiBold"
                                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                            <Border Background="{x:Bind StatusBrush}" 
                                                    CornerRadius="4" 
                                                    Padding="8,4"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind StatusText}" 
                                                           FontSize="12" 
                                                           Foreground="White"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Spacing="16">
                                            <TextBlock FontSize="14" 
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                <Run Text="📅"/>
                                                <Run Text="{x:Bind CreatedDate, Converter={StaticResource ThaiDateConverter}, ConverterParameter=short}"/>
                                            </TextBlock>
                                            <TextBlock FontSize="14" 
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                <Run Text="👤"/>
                                                <Run Text="{x:Bind CreatedBy}"/>
                                            </TextBlock>
                                            <TextBlock FontSize="14" 
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                <Run Text="📦"/>
                                                <Run Text="{x:Bind ItemCount}"/>
                                                <Run Text=" รายการ"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" 
                                                Orientation="Horizontal" 
                                                Spacing="8">
                                        <Button Content="👁️ ดูรายละเอียด" 
                                                Click="ViewButton_Click"
                                                Tag="{x:Bind Id}"
                                                FontSize="14"
                                                Padding="10,6"/>
                                        
                                        <!-- ปุ่มเบิกเพิ่ม - แสดงเฉพาะ InProgress -->
                                        <Button Content="➕ เบิกเพิ่ม" 
                                                Click="AddMoreButton_Click"
                                                Tag="{x:Bind Id}"
                                                Visibility="{x:Bind EditVisibility}"
                                                Style="{StaticResource AccentButtonStyle}"
                                                FontSize="14"
                                                Padding="10,6"/>
                                        
                                        <!-- ปุ่มคืนสินค้า - แสดงเฉพาะ InProgress -->
                                        <Button Content="🔄 คืนสินค้า" 
                                                Click="ReturnButton_Click"
                                                Tag="{x:Bind Id}"
                                                Visibility="{x:Bind EditVisibility}"
                                                FontSize="14"
                                                Padding="10,6"/>
                                        
                                        <!-- ปุ่มลบ - แสดงเฉพาะ Draft ที่ไม่มีรายการ -->
                                        <Button Content="🗑️ ลบ" 
                                                Click="DeleteButton_Click"
                                                Tag="{x:Bind Id}"
                                                Visibility="{x:Bind DeleteVisibility}"
                                                FontSize="14"
                                                Padding="10,6">
                                            <Button.Resources>
                                                <SolidColorBrush x:Key="ButtonBackground" Color="#C42B1C"/>
                                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#A52314"/>
                                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#8B1F11"/>
                                            </Button.Resources>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <!-- Separator -->
                                <Border Grid.Row="1" 
                                        Height="1" 
                                        Background="{ThemeResource CardStrokeColorDefaultBrush}"
                                        Margin="0,12"/>

                                <!-- Info Row -->
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="จำนวนเบิก" 
                                                   FontSize="13" 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}">
                                            <Run Text="{x:Bind TotalQuantity}"/>
                                            <Run Text=" หน่วย"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock Text="จำนวนคืน" 
                                                   FontSize="13" 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}">
                                            <Run Text="{x:Bind TotalReturnedQuantity}"/>
                                            <Run Text=" หน่วย"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Spacing="4">
                                        <TextBlock Text="หมายเหตุ" 
                                                   FontSize="13" 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{x:Bind Notes}" 
                                                   FontSize="15"
                                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Pagination controls -->
            <StackPanel x:Name="PaginationPanel"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Spacing="12"
                        Margin="0,12,0,0"
                        Visibility="Collapsed">
                <Button x:Name="PrevPageButton"
                        Content="◀️ Prev"
                        Click="PrevPageButton_Click"
                        Padding="12,6"/>
                <TextBlock x:Name="PageInfoTextBlock"
                           VerticalAlignment="Center"
                           FontSize="15"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                <Button x:Name="NextPageButton"
                        Content="Next ▶️"
                        Click="NextPageButton_Click"
                        Padding="12,6"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
