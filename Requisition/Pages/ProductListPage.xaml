<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Requisition.Pages.ProductListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Requisition.Models"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="0,0,0,16">
            <TextBlock Text="รายการสินค้า" FontSize="32" FontWeight="Bold" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
            <Button x:Name="RefreshButton" 
                    Click="RefreshButton_Click"
                    ToolTipService.ToolTip="รีเฟรช"
                    Style="{StaticResource SubtleButtonStyle}">
                <FontIcon Glyph="&#xE72C;" FontSize="20"/>
            </Button>
        </StackPanel>

        <!-- Search and Filter -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
            <AutoSuggestBox x:Name="SearchBox"
                           PlaceholderText="ค้นหาด้วยรหัสหรือชื่อสินค้า..."
                           Width="300"
                           QueryIcon="Find"
                           TextChanged="SearchBox_TextChanged"
                           FontSize="15"/>
            <ComboBox x:Name="CategoryFilter"
                     PlaceholderText="หมวดหมู่"
                     Width="150"
                     SelectionChanged="CategoryFilter_SelectionChanged"
                     FontSize="15"/>
        </StackPanel>

        <!-- Product List (responsive) -->
        <ListView x:Name="ProductListView" 
                  Grid.Row="2"
                  SelectionMode="None"
                  ScrollViewer.HorizontalScrollMode="Auto"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  IsItemClickEnabled="False"
                  ItemContainerStyle="{StaticResource ListViewItemStyle}"
                  BorderBrush="{ThemeResource SecondaryColorBrush}" BorderThickness="1" CornerRadius="8">

            <!-- Header uses proportional (star) columns and min widths so layout adapts -->
            <ListView.Header>
                <Grid Padding="14,12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource SecondaryColorBrush}" BorderThickness="0,0,0,1" Height="64">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>   <!-- Code -->
                        <ColumnDefinition Width="2*"/>  <!-- Name (wider) -->
                        <ColumnDefinition Width="*"/>   <!-- Category -->
                        <ColumnDefinition Width="*"/>   <!-- Price -->
                        <ColumnDefinition Width="*"/>   <!-- Unit -->
                        <ColumnDefinition Width="*"/>   <!-- LastModified -->
                        <ColumnDefinition Width="*"/>   <!-- Actions -->
                        <ColumnDefinition Width="*"/>   <!-- Status (moved) -->
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="รหัสสินค้า" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" Text="ชื่อสินค้า" FontWeight="SemiBold" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="6,0,0,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Column="2" Text="หมวดหมู่" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Column="3" Text="ราคา" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="0,0,8,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Column="4" Text="หน่วย" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Column="5" Text="แก้ไขล่าสุด" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Column="6" Text="การจัดการ" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="12,0,12,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Column="7" Text="สถานะ" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </Grid>
            </ListView.Header>

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:Product">
                    <Border BorderBrush="{ThemeResource SecondaryColorBrush}" BorderThickness="0,0,0,1" Padding="14,12" MinHeight="72"
                            Background="{x:Bind IsActive, Converter={StaticResource InactiveRowBrushConverter}}"> 
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Code -->
                            <TextBlock Grid.Column="0"
                                       Text="{x:Bind Code, Mode=OneTime}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontFamily="Consolas"
                                       FontWeight="SemiBold"
                                       FontSize="15"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTipService.ToolTip="{x:Bind Code, Mode=OneTime}"/>

                            <!-- Name -->
                            <TextBlock Grid.Column="1"
                                       Text="{x:Bind Name, Mode=OneTime}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontSize="16"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTipService.ToolTip="{x:Bind Name, Mode=OneTime}"
                                       MaxLines="2"/>

                            <!-- Category -->
                            <TextBlock Grid.Column="2"
                                       Text="{x:Bind Category, Mode=OneTime}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontSize="15"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTipService.ToolTip="{x:Bind Category, Mode=OneTime}"/>

                            <!-- Price -->
                            <TextBlock Grid.Column="3"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Padding="0,0,8,0"
                                       FontSize="15"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}">
                                <Run Text="{x:Bind Price, Mode=OneTime}"/>
                                <Run Text=" ฿"/>
                            </TextBlock>

                            <!-- Unit -->
                            <TextBlock Grid.Column="4"
                                       Text="{x:Bind Unit, Mode=OneTime}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontSize="15"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTipService.ToolTip="{x:Bind Unit, Mode=OneTime}"/>

                            <!-- Last Modified -->
                            <!-- ✅ แก้ไขตรงนี้: เพิ่ม Converter และ ConverterParameter -->
                            <TextBlock Grid.Column="5"
                                       Text="{x:Bind LastModifiedDate, Mode=OneTime, Converter={StaticResource ThaiDateConverter}, ConverterParameter=short}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontSize="14"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>

                            <!-- Action buttons -->
                            <StackPanel Grid.Column="6"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Margin="8,0,8,0">

                                <Button ToolTipService.ToolTip="แก้ไข"
                                        Click="EditButton_Click"
                                        Tag="{x:Bind Code}"
                                        Padding="6"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Style="{StaticResource SubtleButtonStyle}">
                                    <FontIcon Glyph="&#xE70F;" FontSize="18" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                </Button>

                                <Button ToolTipService.ToolTip="ดูประวัติ"
                                        Click="HistoryButton_Click"
                                        Tag="{x:Bind Code}"
                                        Padding="6"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Style="{StaticResource SubtleButtonStyle}">
                                    <FontIcon Glyph="&#xE81C;" FontSize="18" Foreground="{ThemeResource SystemFillColorAttentionBrush}"/>
                                </Button>

                                <!-- Disable -->
                                <Button x:Name="DisableButton"
                                        ToolTipService.ToolTip="ปิดใช้งาน"
                                        Click="DisableButton_Click"
                                        Tag="{x:Bind Code}"
                                        Padding="6"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Visibility="{x:Bind IsActive, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Style="{StaticResource SubtleButtonStyle}">
                                    <FontIcon Glyph="&#xE74D;" FontSize="18" Foreground="#C42B1C"/>
                                </Button>

                                <!-- Enable -->
                                <Button x:Name="EnableButton"
                                        ToolTipService.ToolTip="เปิดใช้งาน"
                                        Click="EnableButton_Click"
                                        Tag="{x:Bind Code}"
                                        Padding="6"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Visibility="{x:Bind IsActive, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                        Style="{StaticResource SubtleButtonStyle}">
                                    <FontIcon Glyph="&#xE8FB;" FontSize="18" Foreground="#10893E"/>
                                </Button>
                            </StackPanel>

                            <!-- Status -->
                            <TextBlock Grid.Column="7"
                                       Text="{x:Bind IsActive, Converter={StaticResource ProductStatusConverter}}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontWeight="SemiBold"
                                       FontSize="15"
                                       Foreground="{x:Bind IsActive, Converter={StaticResource ProductStatusColorConverter}}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>

            <!-- Use shared ListViewItem style from App.xaml -->
        </ListView>

        <!-- Loading indicator -->
        <ProgressRing x:Name="LoadingRing" 
                     Grid.Row="2"
                     IsActive="False" 
                     Width="50" 
                     Height="50"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
    </Grid>
</Page>
