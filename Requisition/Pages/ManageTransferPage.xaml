<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Requisition.Pages.ManageTransferPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Requisition.Models"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,16">
            <TextBlock Text="📋 จัดการใบTransfer" 
                       Style="{StaticResource TitleTextBlockStyle}" 
                       FontWeight="Bold"
                       FontSize="32"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
            <TextBlock Text="ดูรายละเอียด และจบงานใบTransfer" 
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       FontSize="17"/>
        </StackPanel>

        <!-- Action Bar -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Side: Refresh + Status Filter -->
            <StackPanel Grid.Column="0" 
                        Orientation="Horizontal" 
                        Spacing="12"
                        VerticalAlignment="Center">
                <Button Content="🔄 รีเฟรช" 
                        Click="RefreshButton_Click"
                        VerticalAlignment="Center"
                        FontSize="16"
                        Padding="14,10"/>
                
                <!-- Status Filter -->
                <StackPanel Orientation="Horizontal" 
                            Spacing="8" 
                            VerticalAlignment="Center">
                    <TextBlock Text="สถานะ:" 
                               VerticalAlignment="Center"
                               FontSize="17"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    <ComboBox x:Name="StatusFilter"
                              Width="200"
                              VerticalAlignment="Center"
                              SelectionChanged="StatusFilter_Changed"
                              FontSize="15">
                        <x:String>ทั้งหมด</x:String>
                        <x:String>กำลังดำเนินการ</x:String>
                        <x:String>จบงานแล้ว</x:String>
                    </ComboBox>
                </StackPanel>
            </StackPanel>

            <!-- Center: Search Box -->
            <AutoSuggestBox x:Name="TransferSearchBox"
                            Grid.Column="1"
                            PlaceholderText="🔍 ค้นหาเลขที่ใบTransfer, ผู้สร้าง, หมายเหตุ..."
                            QueryIcon="Find"
                            TextChanged="TransferSearchBox_TextChanged"
                            Width="480"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="16"
                            Margin="16,0"/>
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="2">
            <ProgressRing x:Name="LoadingRing" 
                          IsActive="False" 
                          Width="64" 
                          Height="64"/>

            <ListView x:Name="TransferListView"
                      SelectionMode="None"
                      Visibility="Collapsed">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Transfer">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="8"
                                Padding="22"
                                Margin="0,10"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Header Row -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Spacing="10">
                                        <StackPanel Orientation="Horizontal" Spacing="14">
                                            <TextBlock Text="{x:Bind TransferNo}" 
                                                       FontSize="20" 
                                                       FontWeight="SemiBold"
                                                       FontFamily="Consolas"/>
                                            <Border Background="{x:Bind StatusBrush}" 
                                                    CornerRadius="4" 
                                                    Padding="10,6">
                                                <TextBlock Text="{x:Bind StatusText}" 
                                                           FontSize="13" 
                                                           Foreground="White"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Spacing="18">
                                            <TextBlock FontSize="15" 
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                <Run Text="📅 สร้างเมื่อ:"/>
                                                <Run Text="{x:Bind CreatedDateDisplay}"/>
                                            </TextBlock>
                                            <TextBlock FontSize="15" 
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                <Run Text="👤"/>
                                                <Run Text="{x:Bind CreatedBy}"/>
                                            </TextBlock>
                                            <TextBlock FontSize="15" 
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                <Run Text="📦"/>
                                                <Run Text="{x:Bind ItemCount}"/>
                                                <Run Text=" รายการ"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" 
                                                Orientation="Horizontal" 
                                                Spacing="10">
                                        <Button Content="📄 รายละเอียด"
                                                Tag="{x:Bind Id}"
                                                Click="ViewDetailsButton_Click"
                                                Style="{StaticResource AccentButtonStyle}"
                                                FontSize="15"
                                                Padding="12,8"/>
                                        
                                        <!-- ปุ่มจบงาน (แสดงเฉพาะ InProgress) -->
                                        <Button Content="✅ จบงาน"
                                                Tag="{x:Bind Id}"
                                                Click="CompleteButton_Click"
                                                Visibility="{x:Bind CompleteButtonVisibility}"
                                                FontSize="15"
                                                Padding="12,8">
                                            <Button.Resources>
                                                <SolidColorBrush x:Key="ButtonBackground" Color="#10B981"/>
                                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#059669"/>
                                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#047857"/>
                                            </Button.Resources>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <!-- Separator -->
                                <Border Grid.Row="1" 
                                        Height="1" 
                                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        Margin="0,14"/>

                                <!-- Info Row -->
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Spacing="6">
                                        <TextBlock Text="จำนวนเบิก" 
                                                   FontSize="14" 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{x:Bind TotalQuantityDisplay}"
                                                   FontSize="18" 
                                                   FontWeight="SemiBold"
                                                   Foreground="#10B981"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Spacing="6">
                                        <TextBlock Text="จำนวนคืน" 
                                                   FontSize="14" 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{x:Bind TotalReturnedDisplay}"
                                                   FontSize="18" 
                                                   FontWeight="SemiBold"
                                                   Foreground="#F59E0B"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Spacing="6">
                                        <TextBlock Text="วันที่ใช้ของ" 
                                                   FontSize="14" 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock FontSize="16" FontWeight="SemiBold">
                                            <Run Text="{x:Bind UsageDateDisplay}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" Spacing="6">
                                        <TextBlock Text="หมายเหตุ" 
                                                   FontSize="14" 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{x:Bind Notes}" 
                                                   FontSize="16"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="2"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Pagination controls -->
            <StackPanel x:Name="PaginationPanel"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Spacing="12"
                        Margin="0,12,0,0"
                        Visibility="Collapsed">
                <Button x:Name="PrevPageButton"
                        Content="◀️ Prev"
                        Click="PrevPageButton_Click"
                        Padding="12,6"/>
                <TextBlock x:Name="PageInfoTextBlock"
                           VerticalAlignment="Center"
                           FontSize="15"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                <Button x:Name="NextPageButton"
                        Content="Next ▶️"
                        Click="NextPageButton_Click"
                        Padding="12,6"/>
            </StackPanel>

            <!-- Empty State -->
            <Border x:Name="EmptyState"
                    Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="44"
                    MinHeight="200">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14">
                    <FontIcon Glyph="&#xE7C3;" FontSize="56" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    <TextBlock Text="ไม่พบใบTransfer" HorizontalAlignment="Center" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Text="ยังไม่มีใบTransferที่สถานะกำลังดำเนินการหรือจบงาน" 
                               Foreground="Gray" 
                               TextAlignment="Center"
                               FontSize="15"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Loading Overlay -->
        <Grid x:Name="LoadingOverlay"
              Grid.RowSpan="3"
              Background="#80000000"
              Visibility="Collapsed">
            <ProgressRing IsActive="True" Width="64" Height="64"/>
        </Grid>
    </Grid>
</Page>
