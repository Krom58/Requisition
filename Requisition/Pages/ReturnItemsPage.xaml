<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Requisition.Pages.ReturnItemsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Requisition.Pages"
    xmlns:models="using:Requisition.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer HorizontalAlignment="Stretch">
        <Grid Padding="24,24,24,40" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Header -->
                <RowDefinition Height="Auto"/>   <!-- Info Cards -->
                <RowDefinition Height="*"/>      <!-- Items Section -->
                <RowDefinition Height="Auto"/>   <!-- Action Buttons -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <Button x:Name="BackButton"
                           Click="BackButton_Click"
                           Style="{StaticResource SubtleButtonStyle}"
                           Padding="10">
                        <FontIcon Glyph="&#xE72B;" FontSize="20"/>
                    </Button>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="🔄 คืนสินค้า"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <TextBlock x:Name="TransferNoText"
                                   FontFamily="Consolas"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Status Badge -->
                <Border x:Name="StatusBadge"
                        Grid.Column="2"
                        CornerRadius="16"
                        Padding="18,8"
                        VerticalAlignment="Center"
                        Background="{ThemeResource SuccessBrush}">
                    <TextBlock x:Name="StatusText"
                               FontWeight="SemiBold"
                               FontSize="15"
                               Foreground="White"
                               TextAlignment="Center"/>
                </Border>
            </Grid>

            <!-- Info Cards -->
            <Grid Grid.Row="1" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Created Info -->
                <Border Grid.Column="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="22"
                        Margin="0,0,12,0"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="2">
                    <StackPanel Spacing="8">
                        <TextBlock Text="📅 วันที่สร้าง" 
                                   FontSize="15" 
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="CreatedDateText" 
                                   FontSize="20" 
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <TextBlock x:Name="CreatedByText" 
                                   FontSize="14" 
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Return Summary -->
                <Border Grid.Column="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="22"
                        Margin="0,0,0,0"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="2">
                    <StackPanel Spacing="8">
                        <TextBlock Text="📋 สรุปการคืน" 
                                   FontSize="15" 
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <StackPanel x:Name="SelectedCountBadgeContainer" 
                                    Orientation="Horizontal" 
                                    Spacing="10" 
                                    VerticalAlignment="Center">
                            <InfoBadge x:Name="SelectedCountBadge"
                                       Value="0"
                                       Background="{ThemeResource AccentFillColorDefaultBrush}"
                                       Margin="0,0,6,0"/>
                            <TextBlock Text="รายการที่เลือก"
                                       FontSize="15"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="SelectedSummaryText" 
                                   Text="เลือกรายการที่ต้องการคืน" 
                                   FontSize="14"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Items Section -->
            <StackPanel Grid.Row="2" Spacing="18" HorizontalAlignment="Stretch">
                
                <!-- Items List Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="0"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    
                    <StackPanel Spacing="0">
                        <!-- Header -->
                        <Grid Padding="16,12" 
                              Background="{ThemeResource LayerFillColorDefaultBrush}"
                              CornerRadius="8,8,0,0">
                            <TextBlock Text="📋 รายการสินค้าที่สามารถคืนได้" 
                                       FontSize="20" 
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </Grid>

                        <!-- Loading/Empty State -->
                        <ProgressRing x:Name="LoadingRing" 
                                      IsActive="False" 
                                      Visibility="Collapsed"
                                      Width="56" 
                                      Height="56" 
                                      Margin="0"/>

                        <StackPanel x:Name="EmptyStatePanel" 
                                    Visibility="Collapsed" 
                                    Padding="24" 
                                    HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE73E;" 
                                      FontSize="48" 
                                      Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                      HorizontalAlignment="Center"/>
                            <TextBlock Text="ไม่มีสินค้าที่ต้องคืน" 
                                       FontSize="18" 
                                       HorizontalAlignment="Center" 
                                       Margin="0,18,0,0"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="คืนครบแล้วหรือยังไม่มีการเบิก" 
                                       FontSize="14" 
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Items ListView -->
                        <ListView x:Name="ReturnItemsListView"
                                  SelectionMode="None"
                                  IsItemClickEnabled="False"
                                  MaxHeight="600"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Margin="0">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:TransferItem">
                                    <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                                            Margin="12,10"
                                            Padding="20"
                                            CornerRadius="8"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <Grid RowSpacing="14">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Product Info with Edit Button -->
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" Spacing="8">
                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                        <TextBlock Text="{x:Bind ProductCode}" 
                                                                   Margin="0,0,0,0"
                                                                   FontWeight="SemiBold" 
                                                                   FontSize="15"
                                                                   FontFamily="Consolas"
                                                                   Foreground="{ThemeResource PrimaryColorBrush}"/>
                                                        <TextBlock Text="-" 
                                                                   Margin="0,-2.5,0,0"
                                                                   FontSize="15"
                                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                        <TextBlock Text="{x:Bind ProductName}" 
                                                                   Margin="0,-5,0,0"
                                                                   FontSize="16"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxWidth="760"/>
                                                    </StackPanel>
                                                
                                                    <!-- Quantity Summary -->
                                                    <StackPanel Orientation="Horizontal" Spacing="18">
                                                        <Border Background="#E6F6FF" 
                                                                Padding="10,6" 
                                                                CornerRadius="6">
                                                            <TextBlock FontSize="13" 
                                                                       Foreground="#0369A1">
                                                                <Run Text="เบิก: "/>
                                                                <Run Text="{x:Bind TotalIssuedQuantity}" 
                                                                     FontWeight="Bold"/>
                                                                <Run Text=" "/>
                                                                <Run Text="{x:Bind Unit}"/>
                                                            </TextBlock>
                                                        </Border>
                                                        
                                                        <Border Background="#FFF6F5" 
                                                                Padding="10,6" 
                                                                CornerRadius="6">
                                                            <TextBlock FontSize="13" 
                                                                       Foreground="#D97706">
                                                                <Run Text="คงเหลือ: "/>
                                                                <Run Text="{x:Bind RemainingQuantity}" 
                                                                     FontWeight="Bold"/>
                                                                <Run Text=" "/>
                                                                <Run Text="{x:Bind Unit}"/>
                                                            </TextBlock>
                                                        </Border>
                                                    </StackPanel>
                                                </StackPanel>

                                                <!-- Edit Button -->
                                                <StackPanel Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            Spacing="8"
                                                            VerticalAlignment="Top">
                                                    <Button Tag="{x:Bind Id}"
                                                            Click="EditReturnItemButton_Click"
                                                            Background="Transparent"
                                                            BorderThickness="1"
                                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                            Padding="10"
                                                            CornerRadius="6"
                                                            ToolTipService.ToolTip="แก้ไขรายการ">
                                                        <FontIcon Glyph="&#xE70F;" 
                                                                  FontSize="18" 
                                                                  Foreground="{ThemeResource PrimaryColorBrush}"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Read-only: selected return quantity (value set via Edit dialog) -->
                                            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                <TextBlock Text="จะคืน:" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                                <TextBlock Text="{x:Bind ReturnQuantity, Mode=OneWay}" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                                                <TextBlock Text="{x:Bind Unit}" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- Action Buttons -->
            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        Spacing="12"
                        HorizontalAlignment="Right"
                        Margin="0,24,0,0">

                <Button Content="ยกเลิก" 
                        Click="CancelButton_Click"
                        MinWidth="100"
                        FontSize="14"/>
                        
                <Button x:Name="SaveButton"
                        Content="💾 บันทึกการคืน" 
                        Click="SaveButton_Click"
                        Style="{StaticResource AccentButtonStyle}"
                        MinWidth="160"
                        FontSize="15"
                        IsEnabled="False"/>
            </StackPanel>

            <!-- Loading Overlay -->
            <Grid x:Name="LoadingOverlay"
                  Grid.RowSpan="4"
                  Background="#80000000"
                  Visibility="Collapsed">
                <ProgressRing IsActive="True" Width="60" Height="60"/>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
