<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Requisition.Pages.OutletDailyCostPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Requisition.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="20" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/> <!-- filters / buttons area (adaptive) -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
            <TextBlock Text="รายงานต้นทุนรายวันตามใบรายงาน ABF" FontSize="20" FontWeight="Bold"/>
        </StackPanel>

        <!-- Adaptive filters + actions -->
        <Grid Grid.Row="1" x:Name="FiltersGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Filters group (Category & Unit removed) -->
            <StackPanel x:Name="FiltersPanel"
                        Orientation="Horizontal"
                        Spacing="12"
                        Grid.Row="0"
                        Grid.Column="0"
                        VerticalAlignment="Center">
                <ComboBox x:Name="MonthCombo" Header="เดือน" Width="140" SelectionChanged="Filter_SelectionChanged"/>
                <ComboBox x:Name="YearCombo" Header="ปี" Width="120" SelectionChanged="Filter_SelectionChanged"/>
                <ComboBox x:Name="OutletCombo" Header="Outlet" Width="220" SelectionChanged="Filter_SelectionChanged"/>
            </StackPanel>

            <!-- Buttons group (default: narrow layout places buttons on its own row) -->
            <StackPanel x:Name="ButtonsPanel"
                        Orientation="Horizontal"
                        Spacing="12"
                        Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        VerticalAlignment="Center">
                <Button x:Name="RefreshButton" Click="RefreshButton_Click" Padding="10,6">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE895;"/>
                        <TextBlock Text="ดึงข้อมูล"/>
                    </StackPanel>
                </Button>

                <Button x:Name="ExportButton" Click="ExportButton_Click" Padding="10,6">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE8E5;"/>
                        <TextBlock Text="ส่งออก CSV"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Small loading indicator in header area -->
            <ProgressRing x:Name="LoadingRingSmall"
                          Width="36"
                          Height="36"
                          IsActive="False"
                          Visibility="Collapsed"
                          Grid.Row="0"
                          Grid.Column="1"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          Margin="8,0,0,0"/>

            <!-- Responsive states -->
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="AdaptiveStates">
                    <VisualState x:Name="WideState">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="720"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="ButtonsPanel.(Grid.Row)" Value="0" />
                            <Setter Target="ButtonsPanel.(Grid.Column)" Value="1" />
                            <Setter Target="ButtonsPanel.(Grid.ColumnSpan)" Value="1" />
                            <Setter Target="ButtonsPanel.HorizontalAlignment" Value="Right" />
                            <Setter Target="FiltersPanel.HorizontalAlignment" Value="Left" />
                        </VisualState.Setters>
                    </VisualState>

                    <VisualState x:Name="NarrowState">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="0"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="ButtonsPanel.(Grid.Row)" Value="1" />
                            <Setter Target="ButtonsPanel.(Grid.Column)" Value="0" />
                            <Setter Target="ButtonsPanel.(Grid.ColumnSpan)" Value="2" />
                            <Setter Target="ButtonsPanel.HorizontalAlignment" Value="Right" />
                            <Setter Target="FiltersPanel.HorizontalAlignment" Value="Stretch" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <ProgressRing x:Name="LoadingRing" Width="48" Height="48" IsActive="False" Visibility="Collapsed" HorizontalAlignment="Center" Margin="0,8" Grid.Row="0"/>

            <!-- Results (table stretches to fill width; no horizontal scroll) -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="0,8,0,0">
                <StackPanel x:Name="ResultsStack" Spacing="12" HorizontalAlignment="Stretch"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
