<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Requisition.Pages.ImportExcelPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <Grid Padding="24" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- File + Sheet (side by side) -->
                <RowDefinition Height="Auto"/> <!-- Column Mapping -->
                <RowDefinition Height="*"/>    <!-- Preview -->
                <RowDefinition Height="Auto"/> <!-- Actions -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Spacing="8">
                <TextBlock Text="Import ข้อมูลจาก Excel" FontSize="28" FontWeight="Bold"/>
                <TextBlock Text="เลือกไฟล์ Excel และกำหนด Column Mapping" Foreground="Gray"/>
            </StackPanel>

            <!-- File Selection + Sheet Selection (side-by-side) -->
            <Grid Grid.Row="1" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- File Selection (left) -->
                <StackPanel Grid.Column="0" Spacing="12" Margin="0,16,0,0">
                    <TextBlock Text="1. เลือกไฟล์ Excel" FontSize="18" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button x:Name="SelectFileButton" 
                                Click="SelectFileButton_Click"
                                Padding="12,8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8E5;" FontSize="18"/>
                                <TextBlock Text="เลือกไฟล์" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <TextBlock x:Name="SelectedFileText" 
                                   Text="ยังไม่ได้เลือกไฟล์" 
                                   VerticalAlignment="Center" 
                                   Foreground="Gray"/>
                    </StackPanel>
                </StackPanel>

                <!-- Sheet Selection (right) -->
                <StackPanel Grid.Column="1" Spacing="12" Margin="16,16,0,0" x:Name="SheetSelectionPanel" Visibility="Collapsed">
                    <TextBlock Text="2. เลือก Sheet" FontSize="18" FontWeight="SemiBold"/>
                    <ComboBox x:Name="SheetComboBox" 
                              Header="Sheet ที่ต้องการ Import"
                              MinWidth="240"
                              SelectionChanged="SheetComboBox_SelectionChanged"/>
                </StackPanel>
            </Grid>

            <!-- Column Mapping -->
            <StackPanel Grid.Row="2" Spacing="12" x:Name="ColumnMappingPanel" Visibility="Collapsed">
                <TextBlock Text="3. กำหนด Column Mapping" FontSize="18" FontWeight="SemiBold"/>

                <Grid ColumnSpacing="16" RowSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: Code & Name -->
                    <ComboBox x:Name="CodeColumnComboBox" 
                              Grid.Row="0" Grid.Column="0"
                              Header="รหัสสินค้า (Code) *"
                              MinWidth="250"/>

                    <ComboBox x:Name="NameColumnComboBox" 
                              Grid.Row="0" Grid.Column="1"
                              Header="ชื่อสินค้า (Name) *"
                              MinWidth="250"/>

                    <!-- Row 1: Category & Unit -->
                    <ComboBox x:Name="CategoryColumnComboBox" 
                              Grid.Row="1" Grid.Column="0"
                              Header="ประเภท (Category)"
                              MinWidth="250"/>

                    <ComboBox x:Name="UnitColumnComboBox" 
                              Grid.Row="1" Grid.Column="1"
                              Header="หน่วย (Unit)"
                              MinWidth="250"/>

                    <!-- Row 2: Price & PriceDate -->
                    <ComboBox x:Name="PriceColumnComboBox" 
                              Grid.Row="2" Grid.Column="0"
                              Header="ราคา (Price)"
                              MinWidth="250"/>

                    <ComboBox x:Name="PriceDateColumnComboBox" 
                              Grid.Row="2" Grid.Column="1"
                              Header="วันที่ราคา (Price Date)"
                              MinWidth="250">
                        <ComboBox.Description>
                            <TextBlock Text="ไม่บังคับ - ถ้าไม่ระบุจะใช้วันที่ Import" 
                                       Foreground="Gray" 
                                       FontSize="12"/>
                        </ComboBox.Description>
                    </ComboBox>

                    <!-- Row 3: Remarks (ใหม่) -->
                    <ComboBox x:Name="RemarksColumnComboBox" 
                              Grid.Row="3" Grid.Column="0"
                              Header="หมายเหตุ (Remarks)"
                              MinWidth="250">
                        <ComboBox.Description>
                            <TextBlock Text="ไม่บังคับ - ถ้าไม่ระบุจะเก็บค่าเดิม" 
                                       Foreground="Gray" 
                                       FontSize="12"/>
                        </ComboBox.Description>
                    </ComboBox>
                </Grid>

                <!-- คำอธิบายเพิ่มเติม -->
                <InfoBar IsOpen="True" 
                         Severity="Informational"
                         Title="💡 เกี่ยวกับวันที่ราคา"
                         Message="ถ้าระบุ column วันที่ราคา: ราคาที่วันที่ น้อยกว่า วันนี้ จะเก็บเป็นประวัติย้อนหลัง (ไม่อัปเดตราคาปัจจุบัน) ส่วนราคาที่วันที่ >= วันนี้ จะอัปเดตเป็นราคาปัจจุบัน"/>

                <Button x:Name="PreviewButton" 
                        Click="PreviewButton_Click"
                        Margin="0,8,0,0"
                        Padding="12,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8A3;" FontSize="18"/>
                        <TextBlock Text="ดูตัวอย่างข้อมูล" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Data Preview -->
            <StackPanel Grid.Row="3" Spacing="12" x:Name="PreviewPanel" Visibility="Collapsed">
                <TextBlock Text="4. ตัวอย่างข้อมูล" FontSize="18" FontWeight="SemiBold"/>

                <InfoBar x:Name="PreviewInfoBar" 
                         IsOpen="True" 
                         Severity="Informational"/>

                <ListView x:Name="PreviewListView"
                          BorderBrush="Gray" 
                          BorderThickness="1">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnSpacing="12" Padding="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding Code}" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="{Binding Name}"/>
                                <TextBlock Grid.Column="2" Text="{Binding Category}"/>
                                <TextBlock Grid.Column="3" Text="{Binding Unit}"/>
                                <TextBlock Grid.Column="4" Text="{Binding Price}"/>
                                <TextBlock Grid.Column="5" 
                                           Text="{Binding PriceDate}" 
                                           FontSize="12" 
                                           Foreground="Gray"/>
                                <TextBlock Grid.Column="6" Text="{Binding Remarks}" FontSize="12" Foreground="DarkGray" TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.Header>
                        <Grid ColumnSpacing="12" Padding="8" Background="{ThemeResource SystemControlBackgroundBaseLowBrush}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="รหัส" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Text="ชื่อสินค้า" FontWeight="Bold"/>
                            <TextBlock Grid.Column="2" Text="ประเภท" FontWeight="Bold"/>
                            <TextBlock Grid.Column="3" Text="หน่วย" FontWeight="Bold"/>
                            <TextBlock Grid.Column="4" Text="ราคา" FontWeight="Bold"/>
                            <TextBlock Grid.Column="5" Text="วันที่ราคา" FontWeight="Bold"/>
                            <TextBlock Grid.Column="6" Text="หมายเหตุ" FontWeight="Bold"/>
                        </Grid>
                    </ListView.Header>
                </ListView>
            </StackPanel>

            <!-- Action Buttons -->
            <StackPanel Grid.Row="4" 
                        Orientation="Horizontal" 
                        Spacing="12" 
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0"
                        x:Name="ActionPanel"
                        Visibility="Collapsed">
                <Button x:Name="ImportButton" 
                        Style="{StaticResource AccentButtonStyle}"
                        Click="ImportButton_Click"
                        Padding="12,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8B5;" FontSize="18"/>
                        <TextBlock Text="Import ข้อมูล" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>