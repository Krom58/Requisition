<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Requisition.Pages.KitchenSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Requisition.Pages"
    xmlns:models="using:Requisition.Models"
    xmlns:conv="using:Requisition.Converters">

    <Page.Resources>
        <conv:StatusIconConverter x:Key="StatusIconConverter"/>
        <conv:StatusColorConverter x:Key="StatusColorConverter"/>
        <conv:StatusTooltipConverter x:Key="StatusTooltipConverter"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid Padding="28" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" HorizontalAlignment="Stretch" Spacing="12">
            <TextBlock Text="ตั้งค่าห้องครัว"
                       FontSize="24"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="12,0,0,0" Spacing="10">
                <Button x:Name="AddButton"
                        Content="เพิ่มห้องครัว"
                        Click="AddButton_Click"
                        Style="{StaticResource AccentButtonStyle}"
                        FontSize="14"
                        Padding="10,8"/>
                <Button x:Name="ViewAllHistoryButton"
                        Content="ดูประวัติทั้งหมด"
                        Click="ViewAllHistoryButton_Click"
                        FontSize="14"
                        Padding="10,8"/>
            </StackPanel>
        </StackPanel>

        <TextBlock Grid.Row="1"
                   Text="รายการห้องครัว"
                   Margin="0,10,0,10"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

        <ListView x:Name="KitchensListView"
                  Grid.Row="2"
                  CornerRadius="8"
                  SelectionMode="Single"
                  IsItemClickEnabled="False"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                  BorderThickness="1"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <ListView.Header>
                <Grid Padding="14,12"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      BorderThickness="0,0,0,1"
                      Height="56"
                      MinWidth="600">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="ชื่อห้องครัว"
                               FontWeight="SemiBold"
                               FontSize="16"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    <TextBlock Grid.Column="1"
                               Text="การกระทำ"
                               FontWeight="SemiBold"
                               FontSize="16"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                </Grid>
            </ListView.Header>

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:Kitchen">
                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="14,12"
                            MinHeight="64"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="260"/>
                            </Grid.ColumnDefinitions>

                            <!-- Name with Badge -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{x:Bind Name, Mode=OneTime}"
                                               FontSize="16"
                                               TextWrapping="Wrap"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                    <Border Background="{ThemeResource SystemFillColorCriticalBrush}"
                                            CornerRadius="4"
                                            Padding="6,2"
                                            VerticalAlignment="Center"
                                            Visibility="{x:Bind IsActive, Mode=OneTime, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <TextBlock Text="ปิดใช้งาน"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <!-- Actions -->
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="10">
                                <Button ToolTipService.ToolTip="แก้ไข"
                                        Click="EditButton_Click"
                                        Tag="{x:Bind Id}"
                                        Padding="8"
                                        Background="Transparent"
                                        BorderThickness="0">
                                    <FontIcon Glyph="&#xE70F;" FontSize="18" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                </Button>

                                <Button ToolTipService.ToolTip="ดูประวัติ"
                                        Click="HistoryButton_Click"
                                        Tag="{x:Bind Id}"
                                        Padding="8"
                                        Background="Transparent"
                                        BorderThickness="0">
                                    <FontIcon Glyph="&#xE81C;" FontSize="18" Foreground="{ThemeResource SystemFillColorAttentionBrush}"/>
                                </Button>

                                <Button Click="ToggleStatusButton_Click"
                                        Tag="{x:Bind Id}"
                                        Padding="8"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        ToolTipService.ToolTip="{x:Bind IsActive, Mode=OneTime, Converter={StaticResource StatusTooltipConverter}}">
                                    <FontIcon FontSize="18"
                                              Glyph="{x:Bind IsActive, Mode=OneTime, Converter={StaticResource StatusIconConverter}}"
                                              Foreground="{x:Bind IsActive, Mode=OneTime, Converter={StaticResource StatusColorConverter}}"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>
    </Grid>
</Page>
