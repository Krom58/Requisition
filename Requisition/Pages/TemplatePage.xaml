<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Requisition.Pages.TemplatePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Requisition.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:conv="using:Requisition.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <local:StatusIconConverter x:Key="StatusIconConverter"/>
        <local:StatusColorConverter x:Key="StatusColorConverter"/>
        <local:StatusTooltipConverter x:Key="StatusTooltipConverter"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <conv:ThaiDateConverter x:Key="ThaiDateConverter"/>
    </Page.Resources>

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- header -->
            <RowDefinition Height="Auto"/>   <!-- subtitle -->
            <RowDefinition Height="*"/>      <!-- list -->
            <RowDefinition Height="Auto"/>   <!-- footer / actions (reserved) -->
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" HorizontalAlignment="Stretch" Spacing="12">
            <TextBlock Text="Template"
                       FontSize="24"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="12,0,0,0" Spacing="8">
                <Button x:Name="AddButton"
                        Content="สร้าง Template"
                        Click="AddButton_Click"
                        Style="{StaticResource AccentButtonStyle}"
                        FontSize="14"
                        Padding="10,8"/>
                <Button x:Name="ViewAllHistoryButton"
                        Content="ดูประวัติทั้งหมด"
                        Click="ViewAllHistoryButton_Click"
                        FontSize="14"
                        Padding="10,8"/>
            </StackPanel>
        </StackPanel>

        <TextBlock Grid.Row="1"
                   Text="รายการ Template"
                   Margin="0,8,0,8"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

        <ListView x:Name="TemplatesListView" Grid.Row="2" CornerRadius="8" SelectionMode="Single" IsItemClickEnabled="False" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource SecondaryColorBrush}" BorderThickness="1">
            <ListView.Header>
                <!-- Make header min-height match item MinHeight and use same padding so columns align -->
                <Grid Padding="14,12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" MinHeight="64" MinWidth="600" BorderBrush="{ThemeResource SecondaryColorBrush}" BorderThickness="0,0,0,1" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>    <!-- Name -->
                        <ColumnDefinition Width="*"/>     <!-- Outlet -->
                        <ColumnDefinition Width="1*"/>    <!-- Count -->
                        <ColumnDefinition Width="260"/>   <!-- Actions -->
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="ชื่อ Template"
                               FontWeight="SemiBold"
                               FontSize="16"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    <TextBlock Grid.Column="1"
                               Text="Outlet"
                               FontWeight="SemiBold"
                               FontSize="16"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    <TextBlock Grid.Column="2"
                               Text="จำนวนวัตถุดิบ"
                               FontWeight="SemiBold"
                               FontSize="16"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    <TextBlock Grid.Column="3"
                               Text="การกระทำ"
                               FontWeight="SemiBold"
                               FontSize="16"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                </Grid>
            </ListView.Header>

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:Template" xmlns:models="using:Requisition.Models">
                    <Border BorderBrush="{ThemeResource SecondaryColorBrush}" BorderThickness="0,0,0,1" Padding="14,12" MinHeight="64" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="260"/>
                            </Grid.ColumnDefinitions>

                            <!-- Name with Badge -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{x:Bind Name, Mode=OneTime}"
                                               FontSize="17"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                    <Border Background="{ThemeResource SystemFillColorCriticalBrush}"
                                            CornerRadius="4"
                                            Padding="6,2"
                                            VerticalAlignment="Center"
                                            Visibility="{x:Bind IsDeleted, Mode=OneTime, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <TextBlock Text="ปิดใช้งาน"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{x:Bind CreatedDate, Mode=OneTime, Converter={StaticResource ThaiDateConverter}}"
                                           FontSize="13"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Margin="0,6,0,0"/>
                            </StackPanel>

                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontSize="15"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                       Padding="0,0,12,0"
                                       Text="{x:Bind OutletName, Mode=OneTime}"/>

                            <TextBlock Grid.Column="2"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontSize="16"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                       Padding="0,0,12,0"
                                       FontWeight="SemiBold"
                                       Text="{x:Bind Ingredients.Count, Mode=OneTime}"/>

                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Button ToolTipService.ToolTip="แก้ไข" Click="EditButton_Click" Tag="{x:Bind Id}" Padding="8" Background="Transparent" BorderThickness="0">
                                    <FontIcon Glyph="&#xE70F;" FontSize="18" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                </Button>

                                <Button ToolTipService.ToolTip="ดูประวัติ" Click="HistoryButton_Click" Tag="{x:Bind Id}" Padding="8" Background="Transparent" BorderThickness="0">
                                    <FontIcon Glyph="&#xE81C;" FontSize="18" Foreground="{ThemeResource SystemFillColorAttentionBrush}"/>
                                </Button>

                                <Button Click="ToggleStatusButton_Click"
                                        Tag="{x:Bind Id}"
                                        Padding="8"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        ToolTipService.ToolTip="{x:Bind IsDeleted, Mode=OneTime, Converter={StaticResource StatusTooltipConverter}}">
                                    <FontIcon FontSize="18"
                                              Glyph="{x:Bind IsDeleted, Mode=OneTime, Converter={StaticResource StatusIconConverter}}"
                                              Foreground="{x:Bind IsDeleted, Mode=OneTime, Converter={StaticResource StatusColorConverter}}"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>
    </Grid>
</Page>
