<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Requisition.Pages.SelectTransfersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Requisition.Pages"
    xmlns:models="using:Requisition.Models"
    xmlns:converters="using:Requisition.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>
    </Page.Resources>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Click="BackButton_Click"
                        Style="{StaticResource SubtleButtonStyle}"
                        Padding="8">
                    <FontIcon Glyph="&#xE72B;" FontSize="18"/>
                </Button>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="➕ สร้างใบรวม Transfer" 
                               Style="{StaticResource TitleTextBlockStyle}" 
                               FontWeight="Bold"
                               FontSize="28"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    <TextBlock Text="เลือกใบ Transfer ที่ต้องการรวม (เฉพาะสถานะ: จบงานแล้ว)" 
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontSize="15"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <!-- Summary Card (Sticky) -->
        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="2"
                CornerRadius="8"
                Padding="20"
                Margin="0,0,0,16">
            <StackPanel Spacing="12">
                <TextBlock Text="📊 สรุปการเลือก" 
                           FontSize="18" 
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                
                <!-- People Count Warning -->
                <Border x:Name="PeopleWarningBorder"
                        Visibility="Collapsed"
                        Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                        BorderBrush="{ThemeResource SystemFillColorCriticalBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE7BA;" 
                                  FontSize="16"
                                  Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                        <TextBlock x:Name="PeopleWarningText"
                                   Text="⚠️ จำนวนคนในแต่ละใบไม่เท่ากัน"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="จำนวนใบที่เลือก" 
                                   FontSize="13"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="SelectedCountText" 
                                   Text="0 ใบ"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{ThemeResource PrimaryColorBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="จำนวนคน" 
                                   FontSize="13"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="PeopleCountText" 
                                   Text="0 คน"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Spacing="4">
                        <TextBlock Text="ยอดรวม" 
                                   FontSize="13"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="TotalCostText" 
                                   Text="0.00 ฿"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{ThemeResource SuccessBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Spacing="4">
                        <TextBlock Text="ราคา/หัว รวม" 
                                   FontSize="13"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="TotalCostPerHeadText" 
                                   Text="0.00 ฿/คน"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{ThemeResource WarningBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4" Spacing="4">
                        <TextBlock Text="ราคาต่อหัวของ Outlet" 
                                   FontSize="13"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="OutletPricePerHeadText" 
                                   Text="-"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    </StackPanel>
                </Grid>

                <!-- เหตุผล -->
                <TextBox x:Name="ReasonTextBox"
                         Header="เหตุผลในการรวม (ไม่บังคับ)"
                         PlaceholderText="ระบุเหตุผล เช่น รวมใบสำหรับงานวันเดียวกัน..."
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         Height="80"
                         FontSize="15"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16">
                <!-- Search & Filter Section -->
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock Text="รายการใบ Transfer ที่พร้อมรวม" 
                                   FontSize="18" 
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <TextBlock x:Name="AvailableCountText" 
                                   Text="(0 ใบ)"
                                   FontSize="15"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Search Boxes -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="SearchTransferNoBox"
                                 Grid.Column="0"
                                 PlaceholderText="🔍 ค้นหาด้วยรหัสใบ Transfer..."
                                 FontSize="15"
                                 TextChanged="SearchBox_TextChanged"/>

                        <ComboBox x:Name="OutletFilterComboBox"
                                  Grid.Column="1"
                                  PlaceholderText="เลือก Outlet"
                                  FontSize="15"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="FilterComboBox_SelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="models:Outlet">
                                    <TextBlock Text="{x:Bind Name}" FontSize="14"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <ComboBox x:Name="KitchenFilterComboBox"
                                  Grid.Column="2"
                                  PlaceholderText="เลือก Kitchen"
                                  FontSize="15"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="FilterComboBox_SelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="models:Kitchen">
                                    <TextBlock Text="{x:Bind Name}" FontSize="14"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <Button Grid.Column="3"
                                Content="ล้างตัวกรอง"
                                Click="ClearSearch_Click"
                                FontSize="15"
                                Padding="16,10"/>
                    </Grid>
                </StackPanel>

                <ProgressRing x:Name="LoadingRing" 
                              IsActive="False"
                              Width="48"
                              Height="48"
                              Visibility="Collapsed"
                              HorizontalAlignment="Center"/>

                <!-- List Header (Sticky) -->
                <Border x:Name="ListHeader"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        Visibility="{x:Bind TransfersListView.Visibility, Mode=OneWay}">
                    <Grid>
                        <!-- responsive (star-based) columns with min widths -->
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.4*" MinWidth="110"/>
                            <ColumnDefinition Width="1.2*" MinWidth="90"/>
                            <ColumnDefinition Width="1.2*" MinWidth="90"/>
                            <ColumnDefinition Width="1.6*" MinWidth="110"/>
                            <ColumnDefinition Width="0.9*" MinWidth="68"/>
                            <ColumnDefinition Width="0.9*" MinWidth="68"/>
                            <ColumnDefinition Width="1.1*" MinWidth="85"/>
                            <ColumnDefinition Width="1.1*" MinWidth="85"/>
                            <ColumnDefinition Width="0.9*" MinWidth="75"/>
                            <ColumnDefinition Width="0.7*" MinWidth="48"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="รหัสใบ" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Outlet" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="ครัว" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="วันที่สร้าง" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="จำนวนคน" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="วัตถุดิบ" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="6" Text="ยอดรวม" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="7" Text="ต้นทุน/คน" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="8" Text="งบ" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="9" Text="เลือก" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Transfer List -->
                <ListView x:Name="TransfersListView"
                          SelectionMode="None"
                          Visibility="Collapsed"
                          ItemContainerStyle="{StaticResource ListViewItemStyle}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:SelectableTransferViewModel">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12"
                                    Margin="0,4"
                                    Opacity="{x:Bind IsAlreadyCombined, Converter={StaticResource BoolToOpacityConverter}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <!-- match header proportions (star-based) -->
                                        <ColumnDefinition Width="1.4*"/>
                                        <ColumnDefinition Width="1.2*"/>
                                        <ColumnDefinition Width="1.2*"/>
                                        <ColumnDefinition Width="1.6*"/>
                                        <ColumnDefinition Width="0.9*"/>
                                        <ColumnDefinition Width="0.9*"/>
                                        <ColumnDefinition Width="1.1*"/>
                                        <ColumnDefinition Width="1.1*"/>
                                        <ColumnDefinition Width="0.9*"/>
                                        <ColumnDefinition Width="0.7*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Transfer No -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="2">
                                        <TextBlock Text="{x:Bind TransferNo}" 
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="{x:Bind BoundCombinedDisplay}"
                                                   FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                   Visibility="{x:Bind IsAlreadyCombined, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </StackPanel>

                                    <!-- Outlet Name -->
                                    <TextBlock Grid.Column="1" 
                                               Text="{x:Bind OutletName}" 
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                    <!-- Kitchen Name -->
                                    <TextBlock Grid.Column="2" 
                                               Text="{x:Bind KitchenName}" 
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                    <!-- Created Date -->
                                    <TextBlock Grid.Column="3" 
                                               Text="{x:Bind CreatedDateDisplay}" 
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                    <!-- Expected People -->
                                    <TextBlock Grid.Column="4" 
                                               Text="{x:Bind ExpectedPeopleDisplay}" 
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                                    <!-- Total Quantity -->
                                    <TextBlock Grid.Column="5" 
                                               Text="{x:Bind TotalQuantityDisplay}" 
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                                    <!-- Total Cost -->
                                    <TextBlock Grid.Column="6" 
                                               Text="{x:Bind TotalCostDisplay}" 
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Foreground="{ThemeResource SuccessBrush}"/>

                                    <!-- Cost Per Person -->
                                    <TextBlock Grid.Column="7" 
                                               Text="{x:Bind CostPerPersonDisplay}" 
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Foreground="{ThemeResource WarningBrush}"/>

                                    <!-- Outlet Price -->
                                    <TextBlock Grid.Column="8" 
                                               Text="{x:Bind OutletPricePerHeadDisplay}" 
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Foreground="{x:Bind OutletPriceBrush}"
                                               Margin="0,0,6,0"/>

                                    <!-- Checkbox -->
                                    <CheckBox Grid.Column="9"
                                              Visibility="Visible"
                                              IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                              IsEnabled="{x:Bind IsSelectable}"
                                              Checked="TransferCheckBox_Changed"
                                              Unchecked="TransferCheckBox_Changed"
                                              Margin="36,0,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Empty State -->
                <StackPanel x:Name="EmptyStatePanel"
                            Visibility="Collapsed"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="16"
                            Padding="48">
                    <FontIcon Glyph="&#xE7C3;" 
                              FontSize="64"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    <TextBlock Text="ไม่มีใบ Transfer ที่พร้อมรวม" 
                               FontSize="18"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="ต้องเป็นใบที่สถานะ 'จบงานแล้ว' และยังไม่ถูกรวม" 
                               FontSize="14"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               TextAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <Border Grid.Row="3"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="0,16,0,0"
                Margin="-24,16,-24,-24">
            <StackPanel Orientation="Horizontal"
                        Spacing="12"
                        HorizontalAlignment="Right"
                        Margin="24,0">
                <Button Content="ยกเลิก"
                        Click="CancelButton_Click"
                        MinWidth="120"
                        FontSize="15"
                        Padding="16,10"/>
                
                <Button x:Name="CreateButton"
                        Content="สร้างใบรวม"
                        Click="CreateButton_Click"
                        Style="{StaticResource AccentButtonStyle}"
                        IsEnabled="False"
                        MinWidth="120"
                        FontSize="15"
                        Padding="16,10"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
