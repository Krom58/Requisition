<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Requisition.Pages.CombineTransfersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Requisition.Pages"
    xmlns:models="using:Requisition.Models"
    RequestedTheme="Light">

    <!-- Make entire page scrollable; keep internal ListView scrolling (set MaxHeight) to avoid nested scroll conflicts -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Padding="16" RowSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="480"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Transfers list -->
            <StackPanel Grid.Column="0" Spacing="8">
                <TextBlock Text="รวมใบTransfer" FontSize="20" FontWeight="SemiBold"/>
                <TextBlock Text="เลือกเฉพาะใบที่สถานะ: จบงาน (Completed). เมื่อเลือกแล้วจะถูกปิดการเลือกไม่ให้เลือกซ้ำ" TextWrapping="Wrap" Foreground="{StaticResource TextFillColorSecondaryBrush}" FontSize="12"/>
                <Border Background="{StaticResource CardBackgroundFillColorDefaultBrush}" Padding="12" CornerRadius="6" BorderBrush="{StaticResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock x:Name="AvailableCountText" Text="โหลดข้อมูล..." Margin="0,0,0,8"/>
                        <!-- keep ListView internal scrolling by giving it a MaxHeight -->
                        <ListView x:Name="TransfersListView"
                                  SelectionMode="None"
                                  IsItemClickEnabled="False"
                                  ScrollViewer.VerticalScrollMode="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  MaxHeight="580">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:TransferViewModel">
                                    <Border Padding="8" Margin="0,0,0,8" Background="Transparent">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="36"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0"
                                                      IsEnabled="{x:Bind IsSelectable}"
                                                      IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                                      Checked="TransferCheckBox_Checked"
                                                      Unchecked="TransferCheckBox_Unchecked"
                                                      Tag="{x:Bind Id}"/>
                                            <StackPanel Grid.Column="1" Spacing="4">
                                                <TextBlock Text="{x:Bind DisplayTitle}" FontWeight="SemiBold"/>
                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                    <TextBlock Text="{x:Bind OutletDisplay}" Foreground="{StaticResource TextFillColorSecondaryBrush}"/>
                                                    <TextBlock Text="{x:Bind CreatedDateDisplay}" Foreground="{StaticResource TextFillColorTertiaryBrush}"/>
                                                    <TextBlock Text=" | "/>
                                                    <TextBlock Text="ใช้วันที่:" Foreground="{StaticResource TextFillColorTertiaryBrush}"/>
                                                    <TextBlock Text="{x:Bind UsageDateDisplay}" Foreground="{StaticResource TextFillColorTertiaryBrush}"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind CostPerPersonDisplay}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="งบร้านค้า:" Foreground="{StaticResource TextFillColorTertiaryBrush}"/>
                                                    <TextBlock Text="{x:Bind OutletPricePerHeadDisplay}" Foreground="{x:Bind OutletPriceBrush}" FontWeight="SemiBold"/>
                                                    <TextBlock Text=" | จำนวนวัตถุดิบ:" Foreground="{StaticResource TextFillColorTertiaryBrush}"/>
                                                    <TextBlock Text="{x:Bind TotalQuantityDisplay}" />
                                                    <TextBlock Text=" | ยอดรวม:" Foreground="{StaticResource TextFillColorTertiaryBrush}"/>
                                                    <TextBlock Text="{x:Bind TotalCostDisplay}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Right: Aggregated summary + Actions + History -->
            <StackPanel Grid.Column="1" Spacing="12" Margin="16,0,0,0">
                <TextBlock Text="สรุปการรวม" FontSize="18" FontWeight="SemiBold"/>
                <Border Background="{StaticResource CardBackgroundFillColorDefaultBrush}" Padding="12" CornerRadius="6" BorderBrush="{StaticResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="จำนวนใบที่เลือก:" FontWeight="SemiBold"/>
                            <TextBlock x:Name="SelectedCountText" Text="0"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="จำนวนวัตถุดิบรวม:" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TotalQuantityText" Text="0.0000"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="จำนวนเงินรวม:" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TotalCostText" Text="0.0000 ฿"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="ราคาต่อหัว (รวม):" FontWeight="SemiBold"/>
                            <TextBlock x:Name="CombinedCostPerHeadText" Text="0.0000 ฿/คน" FontWeight="SemiBold"/>
                        </StackPanel>

                        <TextBlock x:Name="CombinedWarningText" Text="" Foreground="{StaticResource DangerBrush}" Visibility="Collapsed"/>

                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
                            <Button x:Name="CombineButton" Content="บันทึกการรวม" Click="CombineButton_Click"/>
                            <Button x:Name="ClearSelectionButton" Content="ล้างการเลือก" Click="ClearSelectionButton_Click"/>
                            <Button x:Name="CloseButton" Content="ปิด" Click="CloseButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock Text="ประวัติการรวม" FontSize="16" FontWeight="SemiBold"/>
                <Border Background="{StaticResource CardBackgroundFillColorDefaultBrush}" Padding="8" CornerRadius="6" BorderBrush="{StaticResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel>
                        <ListView x:Name="CombinedHistoryListView" SelectionMode="Single" IsItemClickEnabled="True" ItemClick="CombinedHistoryListView_ItemClick"
                                  ScrollViewer.VerticalScrollMode="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  MaxHeight="360">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:CombinedHistoryViewModel">
                                    <StackPanel Orientation="Vertical" Padding="6">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <TextBlock Text="{x:Bind CombinedNo}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{x:Bind CreatedDateDisplay}" Foreground="{StaticResource TextFillColorTertiaryBrush}"/>
                                            <TextBlock Text=" | " Foreground="{StaticResource TextFillColorTertiaryBrush}"/>
                                            <TextBlock Text="{x:Bind CreatedBy}" Foreground="{StaticResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <TextBlock Text="จำนวนใบ:" Foreground="{StaticResource TextFillColorTertiaryBrush}"/>
                                            <TextBlock Text="{x:Bind CombinedCount}"/>
                                            <TextBlock Text=" | ยอดรวม:" Foreground="{StaticResource TextFillColorTertiaryBrush}"/>
                                            <TextBlock Text="{x:Bind TotalCostDisplay}"/>
                                            <TextBlock Text=" | จำนวนวัตถุดิบ:" Foreground="{StaticResource TextFillColorTertiaryBrush}"/>
                                            <TextBlock Text="{x:Bind TotalQuantityDisplay}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- Details panel for selected combined record -->
                        <StackPanel x:Name="CombinedDetailsPanel" Visibility="Collapsed" Margin="0,8,0,0">
                            <TextBlock Text="รายละเอียดการรวม (คลิกเพื่อขยาย)" FontWeight="SemiBold"/>
                            <ListView x:Name="CombinedSourcesListView" Height="200"
                                      ScrollViewer.VerticalScrollMode="Auto"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:Transfer">
                                        <StackPanel Orientation="Horizontal" Padding="6" Spacing="12">
                                            <TextBlock Text="{x:Bind TransferNo}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{x:Bind OutletDisplay}" Foreground="{StaticResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{x:Bind UsageDateDisplay}" Foreground="{StaticResource TextFillColorTertiaryBrush}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock Text="หมายเหตุ: หากเลือกใบเสร็จแล้ว รายการในหน้าจอนี้จะปิดการเลือกไม่ให้เลือกซ้ำ" Foreground="{StaticResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" FontSize="12"/>
            </StackPanel>

            <!-- Loading indicator -->
            <ProgressRing x:Name="LoadingRing" Width="36" Height="36"
                          HorizontalAlignment="Right" VerticalAlignment="Top"
                          IsActive="False" Visibility="Collapsed"/>
        </Grid>
    </ScrollViewer>
</Page>
