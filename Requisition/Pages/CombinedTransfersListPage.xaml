<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Requisition.Pages.CombinedTransfersListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Requisition.Pages"
    xmlns:models="using:Requisition.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,16">
            <TextBlock Text="📊 รวมใบTransfer" 
                       Style="{StaticResource TitleTextBlockStyle}" 
                       FontWeight="Bold"
                       FontSize="32"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
            <TextBlock Text="จัดการและดูรายละเอียดการรวมใบTransfer" 
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       FontSize="17"/>
        </StackPanel>

        <!-- Action Bar -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left Side: Refresh + Filters -->
            <StackPanel Grid.Column="0" 
                        Orientation="Horizontal" 
                        Spacing="12"
                        VerticalAlignment="Center">
                <Button Content="🔄 รีเฟรช" 
                        Click="RefreshButton_Click"
                        VerticalAlignment="Center"
                        FontSize="16"
                        Padding="14,8"/>
                
                <!-- History All Button -->
                <Button x:Name="HistoryAllButton"
                        Content="📚 ประวัติทั้งหมด"
                        Click="HistoryAllButton_Click"
                        VerticalAlignment="Center"
                        FontSize="16"
                        Padding="14,8"
                        ToolTipService.ToolTip="แสดงประวัติทั้งหมดของใบรวม (สามารถเลื่อนดูได้)"/>

                <!-- Show Deleted Checkbox -->
                <CheckBox x:Name="ShowDeletedCheckBox"
                          Content="แสดงรายการที่ถูกลบ"
                          Checked="ShowDeletedCheckBox_Changed"
                          Unchecked="ShowDeletedCheckBox_Changed"
                          VerticalAlignment="Center"
                          FontSize="15"/>
            </StackPanel>

            <!-- Center: Search Box -->
            <AutoSuggestBox x:Name="CombinedSearchBox"
                            Grid.Column="1"
                            PlaceholderText="🔍 ค้นหาเลขที่ใบรวม, ผู้สร้าง, รหัสใบTransfer..."
                            QueryIcon="Find"
                            TextChanged="CombinedSearchBox_TextChanged"
                            Width="480"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="16"
                            Margin="16,0"/>

            <!-- Right Side: Create Button -->
            <Button Grid.Column="2"
                    Content="➕ สร้างใบรวมใหม่" 
                    Click="CreateButton_Click"
                    Style="{StaticResource AccentButtonStyle}"
                    VerticalAlignment="Center"
                    FontSize="16"
                    Padding="14,8"/>
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="2">
            <ProgressRing x:Name="LoadingRing" 
                          IsActive="False" 
                          Width="64" 
                          Height="64"/>

            <ListView x:Name="CombinedListView"
                      SelectionMode="None"
                      Visibility="Collapsed"
                      ItemContainerStyle="{StaticResource ListViewItemStyle}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:CombinedTransferListViewModel">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="8"
                                Padding="22"
                                Margin="0,10"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Header Row -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <TextBlock Text="{x:Bind CombinedNo}" 
                                                       FontSize="22" 
                                                       FontWeight="SemiBold"
                                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                            
                                            <!-- Badge: จำนวนใบ -->
                                            <Border Background="{ThemeResource PrimaryColorBrush}" 
                                                    CornerRadius="4" 
                                                    Padding="10,5"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind CombinedCountDisplay}" 
                                                           FontSize="13" 
                                                           Foreground="White"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                            
                                            <!-- Badge: ถูกลบ -->
                                            <Border Background="#C42B1C" 
                                                    CornerRadius="4" 
                                                    Padding="10,5"
                                                    VerticalAlignment="Center"
                                                    Visibility="{x:Bind DeletedBadgeVisibility}">
                                                <TextBlock Text="🗑️ ถูกลบ" 
                                                           FontSize="13" 
                                                           Foreground="White"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Spacing="16">
                                            <TextBlock FontSize="15" 
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                <Run Text="📅"/>
                                                <Run Text="{x:Bind CreatedDate}"/>
                                            </TextBlock>
                                            <TextBlock FontSize="15" 
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                <Run Text="👤"/>
                                                <Run Text="{x:Bind CreatedBy}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        
                                        <!-- แสดงรหัสใบ Transfer -->
                                        <TextBlock FontSize="14" 
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                   TextWrapping="Wrap">
                                            <Run Text="📦 ใบที่รวม:"/>
                                            <Run Text="{x:Bind TransferNosDisplay}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Action Buttons -->
                                    <StackPanel Grid.Column="1" 
                                                Orientation="Horizontal" 
                                                Spacing="8"
                                                Visibility="{x:Bind ActionButtonsVisibility}">
                                        <Button Content="📜 ประวัติ"
                                                Click="HistoryButton_Click"
                                                Tag="{x:Bind Id}"
                                                FontSize="15"
                                                Padding="12,8"/>
                                        <Button Content="👁️ ดูรายละเอียด" 
                                                Click="ViewButton_Click"
                                                Tag="{x:Bind Id}"
                                                FontSize="15"
                                                Padding="12,8"/>
                                        
                                        <Button Content="✏️ แก้ไข" 
                                                Click="EditButton_Click"
                                                Tag="{x:Bind Id}"
                                                Style="{StaticResource AccentButtonStyle}"
                                                FontSize="15"
                                                Padding="12,8"/>
                                        
                                        <Button Content="🗑️ ลบ" 
                                                Click="DeleteButton_Click"
                                                Tag="{x:Bind Id}"
                                                FontSize="15"
                                                Padding="12,8">
                                            <Button.Resources>
                                                <SolidColorBrush x:Key="ButtonBackground" Color="#C42B1C"/>
                                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#A52314"/>
                                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#8B1F11"/>
                                            </Button.Resources>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <!-- Separator -->
                                <Border Grid.Row="1" 
                                        Height="1" 
                                        Background="{ThemeResource CardStrokeColorDefaultBrush}"
                                        Margin="0,14"/>

                                <!-- Info Row -->
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="120"/>
                                        <ColumnDefinition Width="Auto" MinWidth="120"/>
                                        <ColumnDefinition Width="Auto" MinWidth="140"/>
                                        <ColumnDefinition Width="Auto" MinWidth="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 1. จำนวนใบที่เลือก -->
                                    <StackPanel Grid.Column="0" Spacing="6" Margin="0,0,16,0">
                                        <TextBlock Text="จำนวนใบที่เลือก" 
                                                   FontSize="14" 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{x:Bind CombinedCountDisplay}"
                                                   FontSize="20" 
                                                   FontWeight="SemiBold" 
                                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                    </StackPanel>

                                    <!-- 2. จำนวนคน (พร้อมเช็คความสอดคล้อง) -->
                                    <StackPanel Grid.Column="1" Spacing="6" Margin="0,0,16,0">
                                        <TextBlock Text="จำนวนคน" 
                                                   FontSize="14" 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{x:Bind PeopleCountDisplay}"
                                                       FontSize="20" 
                                                       FontWeight="SemiBold" 
                                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                            <!-- แสดง warning ถ้าจำนวนคนไม่เท่ากัน -->
                                            <FontIcon Glyph="&#xE7BA;" 
                                                      FontSize="18"
                                                      Foreground="#F7630C"
                                                      Visibility="{x:Bind PeopleCountWarningVisibility}"
                                                      ToolTipService.ToolTip="จำนวนคนในแต่ละใบไม่เท่ากัน"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- 3. ยอดรวม -->
                                    <StackPanel Grid.Column="2" Spacing="6" Margin="0,0,16,0">
                                        <TextBlock Text="ยอดรวม" 
                                                   FontSize="14" 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{x:Bind TotalCostDisplay}"
                                                   FontSize="20" 
                                                   FontWeight="SemiBold" 
                                                   Foreground="{ThemeResource SuccessBrush}"/>
                                    </StackPanel>

                                    <!-- 4. ราคา/หัว -->
                                    <StackPanel Grid.Column="3" Spacing="6" Margin="0,0,16,0">
                                        <TextBlock Text="ราคา/หัว" 
                                                   FontSize="14" 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{x:Bind CostPerHeadDisplay}"
                                                   FontSize="20" 
                                                   FontWeight="SemiBold" 
                                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                    </StackPanel>

                                    <!-- 5 & 6. รวมแต่ละใบ และ งบตาม outlet -->
                                    <StackPanel Grid.Column="4" Spacing="10">
                                        <!-- รวมแต่ละใบ -->
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="รวมแต่ละใบ" 
                                                       FontSize="14" 
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{x:Bind IndividualTransferCostsDisplay}" 
                                                       FontSize="14"
                                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <!-- ราคาต่อหัวของ Outlet -->
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="ราคาต่อหัวของ Outlet" 
                                                       FontSize="14" 
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{x:Bind OutletPricePerHeadDisplay}" 
                                                       FontSize="14"
                                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            
            <!-- Pagination controls -->
            <StackPanel x:Name="PaginationPanel"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Spacing="12"
                        Margin="0,12,0,0"
                        Visibility="Collapsed">
                <Button x:Name="PrevPageButton"
                        Content="◀️ Prev"
                        Click="PrevPageButton_Click"
                        Padding="12,6"/>
                <TextBlock x:Name="PageInfoTextBlock"
                           VerticalAlignment="Center"
                           FontSize="15"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                <Button x:Name="NextPageButton"
                        Content="Next ▶️"
                        Click="NextPageButton_Click"
                        Padding="12,6"/>
            </StackPanel>

            <!-- Empty State -->
            <StackPanel x:Name="EmptyStatePanel"
                        Visibility="Collapsed"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="16">
                <FontIcon Glyph="&#xE7C3;" 
                          FontSize="72" 
                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                <TextBlock Text="ยังไม่มีรายการรวมใบTransfer" 
                           FontSize="20" 
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Button Content="สร้างใบรวมแรก"
                        Click="CreateButton_Click"
                        Style="{StaticResource AccentButtonStyle}"
                        FontSize="16"
                        Padding="12,8"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
