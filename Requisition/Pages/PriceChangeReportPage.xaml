<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Requisition.Pages.PriceChangeReportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Requisition.Pages"
    xmlns:models="using:Requisition.Models.Reports"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/> <!-- pagination row -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,16">
            <TextBlock Text="⚠️ รายงานการเปลี่ยนแปลงราคา"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
            <TextBlock Text="แสดงสินค้าที่มีการเปลี่ยนแปลงราคาเกินเกณฑ์ที่กำหนด"
                       FontSize="14"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- Filters -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 1: Filters -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
                <NumberBox x:Name="ThresholdBox"
                           Header="เกณฑ์ % การเปลี่ยนแปลง"
                           Width="120"
                           Value="10"
                           Minimum="0"
                           Maximum="100"
                           SpinButtonPlacementMode="Inline"
                           ValueChanged="FilterChanged"/>

                <TextBox x:Name="SearchBox"
                         Header="ค้นหา (ชื่อ/รหัส)"
                         Width="220"
                         PlaceholderText="พิมพ์ชื่อหรือรหัสสินค้า..."
                         TextChanged="FilterChanged"/>

                <ComboBox x:Name="CategoryCombo"
                          Header="ประเภท"
                          Width="160"
                          SelectionChanged="FilterChanged">
                    <ComboBoxItem Content="ทั้งหมด" Tag="All" IsSelected="True"/>
                    <!-- รายการประเภทจะถูกเติมจากโค้ดเบื้องหลัง -->
                </ComboBox>

                <CalendarDatePicker x:Name="StartDatePicker"
                                    Header="วันที่เริ่มต้น"
                                    Width="150"
                                    DateChanged="FilterChanged"/>

                <CalendarDatePicker x:Name="EndDatePicker"
                                    Header="วันที่สิ้นสุด"
                                    Width="150"
                                    DateChanged="FilterChanged"/>

                <ComboBox x:Name="StatusCombo"
                          Header="สถานะ"
                          Width="120"
                          SelectionChanged="FilterChanged">
                    <ComboBoxItem Content="ทั้งหมด" Tag="All" IsSelected="True"/>
                    <ComboBoxItem Content="ใช้งาน" Tag="Active"/>
                    <ComboBoxItem Content="ไม่ใช้งาน" Tag="Inactive"/>
                </ComboBox>
            </StackPanel>

            <!-- Row 2: Buttons -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12">
                <Button x:Name="RefreshButton"
                        Content="🔄 รีเฟรช"
                        Click="RefreshButton_Click"
                        Padding="12,8"/>
                <Button x:Name="ExportButton"
                        Content="📤 ส่งออก CSV"
                        Click="ExportButton_Click"
                        Style="{StaticResource AccentButtonStyle}"
                        Padding="12,8"/>
                <Button x:Name="PrintButton"
                        Content="🖨️ พิมพ์"
                        Click="PrintButton_Click"
                        Padding="12,8"/>
            </StackPanel>
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="2">
            <ProgressRing x:Name="LoadingRing"
                          IsActive="False"
                          Width="60"
                          Height="60"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>

            <ListView x:Name="ReportListView"
                      Visibility="Collapsed"
                      SelectionMode="None">
                <ListView.Header>
                    <Grid Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="สินค้า" Grid.Column="0" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock Text="ราคาเดิม" Grid.Column="1" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Right"/>
                        <TextBlock Text="ราคาใหม่" Grid.Column="2" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Right"/>
                        <TextBlock Text="เปลี่ยนแปลง" Grid.Column="3" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Right"/>
                        <TextBlock Text="%" Grid.Column="4" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Right"/>
                        <TextBlock Text="สถานะ" Grid.Column="5" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Center"/>
                        <TextBlock Text="จัดการ" Grid.Column="6" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Center"/>
                    </Grid>
                </ListView.Header>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:PriceChangeReportItem">
                        <Border Margin="0,6" Padding="12"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="8"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="{x:Bind ProductName}" FontSize="15" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock Text="{x:Bind Category}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                                        <Run Text="เปลี่ยนวันที่: "/><Run Text="{x:Bind NewPriceDateDisplay}"/>
                                    </TextBlock>
                                </StackPanel>

                                <TextBlock Grid.Column="1" Text="{x:Bind OldPriceDisplay}" FontSize="14" HorizontalAlignment="Right" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{x:Bind NewPriceDisplay}" FontSize="14" HorizontalAlignment="Right" Foreground="{ThemeResource TextFillColorPrimaryBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="{x:Bind PriceChangeDisplay}" FontSize="14" HorizontalAlignment="Right" Foreground="{ThemeResource SystemFillColorAttentionBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="{x:Bind PercentChangeDisplay}" FontSize="15" FontWeight="Bold" HorizontalAlignment="Right" Foreground="{ThemeResource SystemFillColorCriticalBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="5" Text="{x:Bind StatusDisplay}" FontSize="13" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                
                                <Button Grid.Column="6" 
                                        Content="🚫 Inactive"
                                        Tag="{x:Bind ProductCode}"
                                        Click="DisableProduct_Click"
                                        Padding="8,6"
                                        FontSize="12"
                                        VerticalAlignment="Center"
                                        Margin="8,0,0,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel x:Name="EmptyStatePanel"
                        Visibility="Collapsed"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12">
                <TextBlock Text="ไม่มีสินค้าที่เปลี่ยนแปลงราคาเกินเกณฑ์"
                           FontSize="16"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <!-- Pagination -->
        <StackPanel x:Name="PaginationPanel"
                    Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="12"
                    Margin="0,12,0,0"
                    Visibility="Collapsed">
            <Button x:Name="PrevPageButton"
                    Content="◀️ Prev"
                    Click="PrevPageButton_Click"
                    Padding="12,6"/>
            <TextBlock x:Name="PageInfoTextBlock"
                       VerticalAlignment="Center"
                       FontSize="15"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
            <Button x:Name="NextPageButton"
                    Content="Next ▶️"
                    Click="NextPageButton_Click"
                    Padding="12,6"/>
        </StackPanel>
    </Grid>
</Page>
