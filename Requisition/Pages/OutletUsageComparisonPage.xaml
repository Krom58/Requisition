<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Requisition.Pages.OutletUsageComparisonPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Requisition.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="20" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
            <TextBlock Text="รายงานเปรียบเทียบเปอร์เซ็นต์การใช้สินค้า (ตาม Outlet)" FontSize="20" FontWeight="Bold"/>
        </StackPanel>

        <!-- Responsive filter + action area -->
        <Grid Grid.Row="1" x:Name="FilterActionsGrid">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>   <!-- filters -->
            <ColumnDefinition Width="Auto"/> <!-- buttons on wide screens -->
          </Grid.ColumnDefinitions>

          <!-- Filters group -->
          <StackPanel x:Name="FiltersPanel"
                      Orientation="Horizontal"
                      Spacing="12"
                      Grid.Row="0"
                      Grid.Column="0"
                      VerticalAlignment="Center">
            <DatePicker x:Name="StartDatePicker" Header="วันที่เริ่มต้น" DateChanged="DatePicker_DateChanged"/>
            <DatePicker x:Name="EndDatePicker" Header="วันที่สิ้นสุด" DateChanged="DatePicker_DateChanged"/>
            <ComboBox x:Name="OutletCombo" Header="Outlet" Width="220"/>
          </StackPanel>

            <!-- Buttons group (default: narrow layout places buttons on its own row) -->
            <StackPanel x:Name="ButtonsPanel"
            Orientation="Horizontal"
            Spacing="12"
            Grid.Row="1"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            VerticalAlignment="Center">
                <Button x:Name="RefreshButton" Click="RefreshButton_Click" Padding="10,6">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE895;"/>
                        <TextBlock Text="โหลด" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="ExportButton" Click="ExportButton_Click" Padding="10,6">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE8E5;"/>
                        <TextBlock Text="ส่งออก CSV" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Responsive states -->
          <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="AdaptiveStates">
              <!-- Wide: buttons move to the right column on the same row -->
              <VisualState x:Name="WideState">
                <VisualState.StateTriggers>
                  <AdaptiveTrigger MinWindowWidth="720"/>
                </VisualState.StateTriggers>
                <VisualState.Setters>
                  <Setter Target="ButtonsPanel.(Grid.Row)" Value="0" />
                  <Setter Target="ButtonsPanel.(Grid.Column)" Value="1" />
                  <Setter Target="ButtonsPanel.(Grid.ColumnSpan)" Value="1" />
                  <Setter Target="ButtonsPanel.HorizontalAlignment" Value="Right" />
                  <Setter Target="FiltersPanel.HorizontalAlignment" Value="Left" />
                </VisualState.Setters>
              </VisualState>

              <!-- Narrow: default layout (buttons on second row spanning full width, right-aligned) -->
              <VisualState x:Name="NarrowState">
                <VisualState.StateTriggers>
                  <AdaptiveTrigger MinWindowWidth="0"/>
                </VisualState.StateTriggers>
                <VisualState.Setters>
                  <Setter Target="ButtonsPanel.(Grid.Row)" Value="1" />
                  <Setter Target="ButtonsPanel.(Grid.Column)" Value="0" />
                  <Setter Target="ButtonsPanel.(Grid.ColumnSpan)" Value="2" />
                  <Setter Target="ButtonsPanel.HorizontalAlignment" Value="Right" />
                  <Setter Target="FiltersPanel.HorizontalAlignment" Value="Stretch" />
                </VisualState.Setters>
              </VisualState>
            </VisualStateGroup>
          </VisualStateManager.VisualStateGroups>
        </Grid>

        <!-- Row 2: loading + results (ScrollViewer fills remaining space) -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <ProgressRing x:Name="LoadingRing"
                          Width="48"
                          Height="48"
                          IsActive="False"
                          Visibility="Collapsed"
                          HorizontalAlignment="Center"
                          Margin="0,8"
                          Grid.Row="0"/>

            <!-- Scrollable results area: vertical + horizontal scrolling enabled -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          Padding="0,8,0,0">
                <StackPanel x:Name="ResultsStack" Spacing="18"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
