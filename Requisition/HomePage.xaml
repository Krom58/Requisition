<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Requisition.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="using:Requisition.Pages"
    mc:Ignorable="d">

    <Grid Padding="24">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="24" Margin="0,0,0,24">

                <!-- Header Section -->
                <StackPanel Spacing="8">
                    <TextBlock Text="ภาพรวมระบบ Requisition" 
                               FontSize="36" 
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{x:Bind CurrentDateDisplay, Mode=OneWay}" 
                               FontSize="16" 
                               Foreground="{StaticResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Quick Stats Cards -->
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Today's Transfers -->
                    <Border Grid.Column="0" 
                            Background="{StaticResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{StaticResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="22"
                            MinHeight="150">
                        <StackPanel Spacing="10" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE8F1;" 
                                      FontSize="36" 
                                      Foreground="{StaticResource PrimaryColorBrush}"
                                      HorizontalAlignment="Center"/>
                            <TextBlock Text="{x:Bind TodayTransfersCount, Mode=OneWay}" 
                                       FontSize="32" 
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="ใบ Transfer วันนี้" 
                                       FontSize="16" 
                                       Foreground="{StaticResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Pending Transfers -->
                    <Border Grid.Column="1" 
                            Background="{StaticResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{StaticResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="22"
                            MinHeight="150">
                        <StackPanel Spacing="10" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE7BA;" 
                                      FontSize="36" 
                                      Foreground="{StaticResource WarningBrush}"
                                      HorizontalAlignment="Center"/>
                            <TextBlock Text="{x:Bind PendingTransfersCount, Mode=OneWay}" 
                                       FontSize="32" 
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="รอดำเนินการ" 
                                       FontSize="16" 
                                       Foreground="{StaticResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Total Products -->
                    <Border Grid.Column="2" 
                            Background="{StaticResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{StaticResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="22"
                            MinHeight="150">
                        <StackPanel Spacing="10" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE8F1;" 
                                      FontSize="36" 
                                      Foreground="{StaticResource SecondaryColorBrush}"
                                      HorizontalAlignment="Center"/>
                            <TextBlock Text="{x:Bind TotalProductsCount, Mode=OneWay}" 
                                       FontSize="32" 
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="รายการสินค้า" 
                                       FontSize="16" 
                                       Foreground="{StaticResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- This Month Cost -->
                    <Border Grid.Column="3" 
                            Background="{StaticResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{StaticResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="22"
                            MinHeight="150">
                        <StackPanel Spacing="10" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE9D2;" 
                                      FontSize="36" 
                                      Foreground="{StaticResource AccentColorBrush}"
                                      HorizontalAlignment="Center"/>
                            <TextBlock Text="{x:Bind MonthCostDisplay, Mode=OneWay}" 
                                       FontSize="32" 
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="ต้นทุนเดือนนี้" 
                                       FontSize="16" 
                                       Foreground="{StaticResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Quick Actions -->
                <StackPanel Spacing="12">
                    <TextBlock Text="เมนูด่วน" 
                               FontSize="22" 
                               FontWeight="SemiBold"/>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Click="CreateTransferButton_Click"
                                Style="{StaticResource AccentButtonStyle}"
                                Padding="22,14"
                                MinWidth="180">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE710;" FontSize="20"/>
                                <TextBlock Text="สร้างใบ Transfer" FontSize="17"/>
                            </StackPanel>
                        </Button>

                        <Button Click="ImportExcelButton_Click"
                                Padding="22,14"
                                MinWidth="180">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE8B5;" FontSize="20"/>
                                <TextBlock Text="Import Excel" FontSize="17"/>
                            </StackPanel>
                        </Button>

                        <Button Click="CombineTransfersButton_Click"
                                Padding="22,14"
                                MinWidth="180">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE8F3;" FontSize="20"/>
                                <TextBlock Text="รวมใบ Transfer" FontSize="17"/>
                            </StackPanel>
                        </Button>

                        <Button Click="ViewReportButton_Click"
                                Padding="22,14"
                                MinWidth="180">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE9D2;" FontSize="20"/>
                                <TextBlock Text="รายงานต้นทุน" FontSize="17"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- Recent Activity -->
                <StackPanel Spacing="12">
                    <TextBlock Text="กิจกรรมล่าสุด" 
                                   FontSize="22" 
                                   FontWeight="SemiBold"/>

                    <Border Background="{StaticResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{StaticResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16">
                        <ListView ItemsSource="{x:Bind RecentActivities, Mode=OneWay}"
                                      SelectionMode="None"
                                      MaxHeight="400">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="pages:ActivityItem">
                                    <Grid Padding="12,8" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <FontIcon Grid.Column="0" 
                                                      Glyph="{x:Bind Icon}" 
                                                      FontSize="22"
                                                      Foreground="{StaticResource PrimaryColorBrush}"/>

                                        <StackPanel Grid.Column="1" Spacing="6">
                                            <TextBlock Text="{x:Bind Title}" 
                                                           FontWeight="SemiBold"
                                                           FontSize="16"/>
                                            <TextBlock Text="{x:Bind Description}" 
                                                           FontSize="15"
                                                           Foreground="{StaticResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="2" 
                                                       Text="{x:Bind TimeAgo}" 
                                                       FontSize="13"
                                                       Foreground="{StaticResource TextFillColorTertiaryBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Grid x:Name="LoadingOverlay" 
              Background="#99000000" 
              Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" 
                        HorizontalAlignment="Center" 
                        Spacing="16">
                <ProgressRing IsActive="True" 
                              Width="64" 
                              Height="64"/>
                <TextBlock Text="กำลังโหลดข้อมูล..." 
                           Foreground="White" 
                           FontSize="18"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>