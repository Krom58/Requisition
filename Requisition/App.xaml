<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Requisition.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Requisition"
    xmlns:converters="using:Requisition.Converters"
    RequestedTheme="Light">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Palette (brushes instead of Color) -->
            <SolidColorBrush x:Key="PrimaryColorBrush" Color="#FF626F47"/>    <!-- #626F47 -->
            <SolidColorBrush x:Key="SecondaryColorBrush" Color="#FFA4B465"/>  <!-- #A4B465 -->
            <SolidColorBrush x:Key="SoftBackgroundBrush" Color="#FFF5ECD5"/>   <!-- #F5ECD5 -->
            <SolidColorBrush x:Key="AccentColorBrush" Color="#FFF0BB78"/>     <!-- #F0BB78 -->

            <!-- Semantic / neutral -->
            <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="#FF1F2937"/>
            <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="#FF6B7280"/>
            <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="#FF9CA3AF"/>
            <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush" Color="#FFE6E7E5"/>

            <!-- App-specific brushes used by pages -->
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#FF626F47"/>
            <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="White"/>
            <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="#FFF5ECD5"/>
            <SolidColorBrush x:Key="CardStrokeColorDefaultBrush" Color="#FFA4B465"/>
            <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="#FFF5ECD5"/>

            <!-- Status / semantic colors -->
            <SolidColorBrush x:Key="SuccessBrush" Color="#FF10B981"/>
            <SolidColorBrush x:Key="WarningBrush" Color="#FFF59E0B"/>
            <SolidColorBrush x:Key="DangerBrush" Color="#FFEF4444"/>

            <!-- Converters -->
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:DateFormatConverter x:Key="DateFormatConverter"/>
            <converters:ProductStatusConverter x:Key="ProductStatusConverter"/>
            <converters:ProductStatusColorConverter x:Key="ProductStatusColorConverter"/>
            <converters:InactiveRowBrushConverter x:Key="InactiveRowBrushConverter"/>
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
            <converters:ThaiDateConverter x:Key="ThaiDateConverter"/>  <!-- ✅ เพิ่มบรรทัดนี้ -->

            <!-- Shared ListViewItem style used earlier -->
            <Style x:Key="ListViewItemStyle" TargetType="ListViewItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0,8"/>
                <Setter Property="Background" Value="Transparent"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
